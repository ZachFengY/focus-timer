# ─────────────────────────────────────────────────────────────────────────────
# FocusFlow — Local Development Environment
# Copy to .env: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# JWT secret — must be ≥ 32 chars. Used to sign/verify auth tokens.
# Generate a good one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=focusflow-local-dev-secret-change-me-in-prod!

# Log level: trace | debug | info | warn | error | silent
LOG_LEVEL=debug

# ─── Mobile App (Expo) ────────────────────────────────────────────────────────
# iOS Simulator: http://localhost:3000
# Android Emulator: http://10.0.2.2:3000
# Real device (Expo Go): http://<YOUR_MACHINE_IP>:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# ─── AI (Claude) — OPTIONAL ──────────────────────────────────────────────────
# Without this key, AI features show graceful fallback messages.
# Get a key at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── Future: Supabase (not needed for local dev) ─────────────────────────────
# Uncomment when you have a Supabase project
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Analytics — OPTIONAL ────────────────────────────────────────────────────
# POSTHOG_API_KEY=phc_...
