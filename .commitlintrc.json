{
  "extends": ["@commitlint/config-conventional"],
  "rules": {
    "scope-enum": [
      2,
      "always",
      [
        "api",
        "mobile",
        "web",
        "ui",
        "types",
        "api-client",
        "db",
        "auth",
        "timer",
        "stats",
        "goals",
        "subjects",
        "ai",
        "ci",
        "deps",
        "config",
        "test"
      ]
    ],
    "subject-case": [
      2,
      "never",
      ["sentence-case", "start-case", "pascal-case", "upper-case"]
    ],
    "body-max-line-length": [1, "always", 120]
  }
}
