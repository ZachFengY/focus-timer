{
  "name": "@focusflow/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "expo start --offline",
    "dev:ios": "expo run:ios",
    "dev:android": "expo start --android",
    "dev:web": "expo start --web --offline",
    "build:ios": "eas build --platform ios",
    "build:android": "eas build --platform android",
    "test": "jest --watchAll=false",
    "test:watch": "jest",
    "test:coverage": "jest --coverage --watchAll=false",
    "typecheck": "tsc --noEmit",
    "lint": "eslint app components hooks stores --ext .ts,.tsx",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@expo/vector-icons": "^15.1.1",
    "@focusflow/api-client": "workspace:*",
    "@focusflow/types": "workspace:*",
    "@focusflow/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@shopify/react-native-skia": "^1.3.2",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~51.0.0",
    "expo-background-fetch": "~12.0.1",
    "expo-font": "~12.0.10",
    "expo-linking": "~6.3.1",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.2",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "expo-task-manager": "~11.8.2",
    "nativewind": "^4.0.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10",
    "victory-native": "^41.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@focusflow/config-eslint": "workspace:*",
    "@focusflow/config-typescript": "workspace:*",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-hooks": "^8.0.1",
    "@testing-library/react-native": "^12.7.2",
    "@types/react": "~18.2.79",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.0"
  }
